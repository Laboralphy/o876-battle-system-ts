#!/bin/bash

echo "generating property-programs index"

script_folder=$(dirname "$(realpath "$0")")
target_folder=$(realpath "${script_folder}/../src/property-programs")
index_ts="${target_folder}/index.ts"

# Initialise index file
echo "// File generated by $(basename $0)" > "$index_ts"
echo "import { IPropertyProgram } from '../IPropertyProgram';" >> "$index_ts"

# Import each program class
for this_file in "$target_folder"/*.ts; do
    this_basefile="$(basename $this_file)"
    this_basefile_nots="$(basename $this_file .ts)"
    if [ "$this_basefile" != "index.ts" ]; then
        class_name="$(grep -oP 'export class \K\S+' $this_file)"
        echo "import { $class_name } from './$this_basefile_nots';" >> "$index_ts"
    fi
done

echo "" >> "$index_ts"
echo "export const PropertyPrograms: Record<string, IPropertyProgram> = {" >> "$index_ts"

# Build record entries
for this_file in "$target_folder"/*.ts; do
    this_basefile="$(basename $this_file)"
    this_basefile_nots="$(basename $this_file .ts)"
    if [ "$this_basefile" != "index.ts" ]; then
        class_name="$(grep -oP 'export class \K\S+' $this_file)"
        key="PROPERTY_PROGRAM_$(echo $this_basefile_nots | tr '[:lower:]' '[:upper:]' | tr '-' '_')"
        echo "    $key: new $class_name()," >> "$index_ts"
    fi
done

echo "};" >> "$index_ts"
echo "generated: $index_ts"
